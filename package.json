{
  "name": "folder-path-color",
  "displayName": "Folder Path Color",
  "publisher": "VisbyDev",
  "description": "All subfolders within a specified path will be assigned a color for easy differentiation.",
  "version": "0.0.14",
  "icon": "/images/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jacob-j/vscode-folder-path-color"
  },
  "engines": {
    "vscode": "^1.78.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "properties": {
        "folder-path-color.folders": {
          "type": "array",
          "default": [
            { "path": "{apps,packages,libs,tools}/**" },
            { "path": "**/{apps,packages,libs,tools}/**" },

            { "path": "{app,pages}/**" },
            { "path": "**/{app,pages}/**" },
            { "path": "{components,ui,shadcn}/**" },
            { "path": "**/{components,ui,shadcn}/**" },
            { "path": "{hooks,utils,lib,actions,store,context,types}/**" },
            { "path": "**/{hooks,utils,lib,actions,store,context,types}/**" },

            { "path": "{public,assets,styles,theme}/**" },
            { "path": "**/{public,assets,styles,theme}/**" },

            { "path": "{supabase,prisma,drizzle,convex,vectors}/**" },
            { "path": "**/{supabase,prisma,drizzle,convex,vectors}/**" },
            { "path": "{db,migrations}/**" },
            { "path": "**/{db,migrations}/**" },

            { "path": "{.github,.husky}/**" },
            { "path": "**/{.github,.husky}/**" },
            { "path": "{docker,k8s,terraform}/**" },
            { "path": "**/{docker,k8s,terraform}/**" },
            { "path": "{e2e,cypress}/**" },
            { "path": "**/{e2e,cypress}/**" },

            { "path": "{dist,build,coverage}/**", "color": "ignored" },
            { "path": "**/{dist,build,coverage}/**", "color": "ignored" },
            { "path": "{node_modules}/**", "color": "ignored" },
            { "path": "**/{node_modules}/**", "color": "ignored" }
          ],
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string"
              },
              "color": {
                "type": "string"
              },
              "symbol": {
                "type": "string"
              },
              "tooltip": {
                "type": "string"
              }
            }
          },
          "description": "Array of folder path and color pairs to be colored."
        }
      }
    },
    "colors": [
      {
        "id": "folderPathColor.custom1",
        "description": "Assignable custom color 1 for the Folder Path Color extension",
        "defaults": { "dark": "#FF00FF", "light": "#FF00FF" }
      },
      {
        "id": "folderPathColor.custom2",
        "description": "Assignable custom color 2 for the Folder Path Color extension",
        "defaults": { "dark": "#39FF14", "light": "#39FF14" }
      },
      {
        "id": "folderPathColor.custom3",
        "description": "Assignable custom color 3 for the Folder Path Color extension",
        "defaults": { "dark": "#FF00FF", "light": "#FF00FF" }
      },
      {
        "id": "folderPathColor.custom4",
        "description": "Assignable custom color 4 for the Folder Path Color extension",
        "defaults": { "dark": "#39FF14", "light": "#39FF14" }
      },
      {
        "id": "folderPathColor.custom5",
        "description": "Assignable custom color 5 for the Folder Path Color extension",
        "defaults": { "dark": "#FF00FF", "light": "#FF00FF" }
      },
      {
        "id": "folderPathColor.custom6",
        "description": "Assignable custom color 6 for the Folder Path Color extension",
        "defaults": { "dark": "#39FF14", "light": "#39FF14" }
      },

      {
        "id": "folderPathColor.custom7",
        "description": "Assignable custom color 7 for the Folder Path Color extension",
        "defaults": { "dark": "#FF00FF", "light": "#FF00FF" }
      },
      {
        "id": "folderPathColor.custom8",
        "description": "Assignable custom color 8 for the Folder Path Color extension",
        "defaults": { "dark": "#39FF14", "light": "#39FF14" }
      },
      {
        "id": "folderPathColor.custom9",
        "description": "Assignable custom color 9 for the Folder Path Color extension",
        "defaults": { "dark": "#FF00FF", "light": "#FF00FF" }
      },
      {
        "id": "folderPathColor.custom10",
        "description": "Assignable custom color 10 for the Folder Path Color extension",
        "defaults": { "dark": "#39FF14", "light": "#39FF14" }
      },
      {
        "id": "folderPathColor.custom11",
        "description": "Assignable custom color 11 for the Folder Path Color extension",
        "defaults": { "dark": "#FF00FF", "light": "#FF00FF" }
      },
      {
        "id": "folderPathColor.custom12",
        "description": "Assignable custom color 12 for the Folder Path Color extension",
        "defaults": { "dark": "#39FF14", "light": "#39FF14" }
      },
      {
        "id": "folderPathColor.custom13",
        "description": "Assignable custom color 13 for the Folder Path Color extension",
        "defaults": { "dark": "#FF00FF", "light": "#FF00FF" }
      },
      {
        "id": "folderPathColor.custom14",
        "description": "Assignable custom color 14 for the Folder Path Color extension",
        "defaults": { "dark": "#39FF14", "light": "#39FF14" }
      },
      {
        "id": "folderPathColor.custom15",
        "description": "Assignable custom color 15 for the Folder Path Color extension",
        "defaults": { "dark": "#FF00FF", "light": "#FF00FF" }
      },
      {
        "id": "folderPathColor.custom16",
        "description": "Assignable custom color 16 for the Folder Path Color extension",
        "defaults": { "dark": "#39FF14", "light": "#39FF14" }
      },
      {
        "id": "folderPathColor.custom17",
        "description": "Assignable custom color 17 for the Folder Path Color extension",
        "defaults": { "dark": "#FF00FF", "light": "#FF00FF" }
      },
      {
        "id": "folderPathColor.custom18",
        "description": "Assignable custom color 18 for the Folder Path Color extension",
        "defaults": { "dark": "#39FF14", "light": "#39FF14" }
      },
      {
        "id": "folderPathColor.custom19",
        "description": "Assignable custom color 19 for the Folder Path Color extension",
        "defaults": { "dark": "#FF00FF", "light": "#FF00FF" }
      },
      {
        "id": "folderPathColor.custom20",
        "description": "Assignable custom color 20 for the Folder Path Color extension",
        "defaults": { "dark": "#39FF14", "light": "#39FF14" }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "yarn run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "yarn run compile-tests && yarn run compile && yarn run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/minimatch": "^6.0.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.2.5",
    "@types/vscode": "^1.78.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "@vscode/test-electron": "^2.3.2",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "ts-loader": "^9.4.3",
    "typescript": "^5.1.3",
    "webpack": "^5.85.0",
    "webpack-cli": "^5.1.1"
  },
  "dependencies": {
    "minimatch": "^10.0.3"
  }
}
